   "source": [
    "#W5A16 Viết hàm kiểm tra một số có phải số Amstronhg hay không? Hàm trả về kiểu bool, có tham số là một số nguyên x\n",
    "\n",
    "\n",
    "def is_amstrong(x):\n",
    "    if x<0:\n",
    "        return False\n",
    "    s = str(x)\n",
    "    n = len(s)\n",
    "    tong = sum(int(so)** n for so in s)\n",
    "    return tong == x\n",
    "\n"
   ]
